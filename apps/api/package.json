{
  "name": "@onedegree/api",
  "version": "0.1.0",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --target node --external pdfkit --external exceljs --external pg --outfile dist/server.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.4.0",
    "@onedegree/shared": "workspace:*",
    "@types/pdfkit": "^0.17.5",
    "exceljs": "^4.4.0",
    "hono": "^4.0.0",
    "jose": "^5.0.0",
    "node-fetch": "^3.3.2",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0"
  }
